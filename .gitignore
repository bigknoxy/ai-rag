# .gitignore generated by assistant — ignores common Python, .NET, editor and OS artifacts

# Virtual environments
/.venv/
/venv/
env/
env.bak/
venv*/

# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.pytest_cache/
.mypy_cache/

# Python packaging/build
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.whl

# Test artifacts
test-results/
*.trx
*.coverage
coverage.xml

# Logs and runtime files
*.log
*.pid
*.seed

# Dotnet build outputs
**/bin/
**/obj/

# NuGet and packages
*.nupkg
*.snupkg
packages/
.nuget/
project.lock.json

# Visual Studio and IDEs
.vscode/
.idea/
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# OS generated files
.DS_Store
Thumbs.db

# Environment and secret files
.env
.env.*
secrets.*
local.settings.json

# Misc
*.py[cod]
*.egg
*.egg-info
*.log

# Keep editor config tracked
!.editorconfig
